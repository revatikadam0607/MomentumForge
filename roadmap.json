  "tips": {
    "daily": [
      "Revise yesterday's DSA topic for 10 minutes before starting new problems.",
      "Explain today's concept out loud as if teaching someone \u2014 it reveals gaps fast.",
      "Timebox each problem to 25-30 minutes before checking the solution.",
      "Write your own test cases before running any code."
    ],
    "interview": [
      "Always clarify constraints before writing code in an interview.",
      "Think out loud \u2014 interviewers evaluate your process, not just the answer.",
      "Practice explaining time and space complexity for every solution you write.",
      "Prepare 3 solid stories using the STAR method for behavioral rounds."
    ],
    "coding": [
      "Dry-run your code on a small example before submitting.",
      "Master the 2-pointer and sliding window patterns \u2014 they cover 30% of problems.",
      "Write brute force first, then optimize \u2014 never skip straight to the 'clever' solution.",
      "Track your recurring mistakes in a notes file and review weekly."
    ],
    "placement": [
      "Update your resume every 2 weeks with new projects and skills.",
      "Apply to 5 companies daily, don't wait until you feel 'fully ready'.",
      "Contribute to one open-source repo \u2014 it stands out on a resume.",
      "Mock interviews weekly are worth more than 10 extra hours of solo practice."
    ],
